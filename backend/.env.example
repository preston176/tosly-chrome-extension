# At least one provider key is required. Gemini is tried first; Groq is the fallback.
GEMINI_API_KEY=your_gemini_api_key_here

# Groq free-tier fallback (get a key at https://console.groq.com). Optional but
# recommended: analysis keeps working if Gemini is rate-limited or out of credits.
GROQ_API_KEY=
# Optional: override the Groq model (defaults to llama-3.3-70b-versatile).
GROQ_MODEL=
