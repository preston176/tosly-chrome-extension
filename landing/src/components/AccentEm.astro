---
interface Props {
  tone?: 'red' | 'inherit';
}
const { tone = 'red' } = Astro.props;
---

<em class:list={['accent-em', `accent-${tone}`]}><slot /></em>

<style>
  .accent-em {
    font-family: 'Geist', 'Inter', system-ui, sans-serif;
    font-style: normal;
    font-weight: 800;
    letter-spacing: -0.02em;
  }
  .accent-em.accent-red { color: #ef4444; }
</style>
