  {
    name: 'Figma',
    url: 'https://www.figma.com/legal/privacy/',
    svg: `<svg viewBox="0 0 24 24" fill="currentColor" xmlns="http://www.w3.org/2000/svg"><path d="M15.852 8.981h-4.588V0h4.588c2.476 0 4.49 2.014 4.49 4.49s-2.014 4.491-4.49 4.491zM12.735 7.51h3.117c1.665 0 3.019-1.355 3.019-3.019s-1.354-3.019-3.019-3.019h-3.117V7.51zm0 1.471H8.148c-2.476 0-4.49-2.014-4.49-4.49S5.672 0 8.148 0h4.588v8.981zm-4.587-7.51c-1.665 0-3.019 1.355-3.019 3.019s1.354 3.019 3.019 3.019h3.117V1.471H8.148zm4.587 15.019H8.148c-2.476 0-4.49-2.014-4.49-4.49s2.014-4.49 4.49-4.49h4.588v8.98zM8.148 10.979c-1.665 0-3.019 1.355-3.019 3.019s1.354 3.019 3.019 3.019h3.117v-6.038H8.148zm8.704 9.509c0 2.476-2.014 4.49-4.49 4.49s-4.49-2.014-4.49-4.49 2.014-4.49 4.49-4.49 4.49 2.014 4.49 4.49zm-1.471 0c0-1.665-1.354-3.019-3.019-3.019s-3.019 1.354-3.019 3.019 1.354 3.019 3.019 3.019 3.019-1.354 3.019-3.019z"/></svg>`
  },
  {
    name: 'Linear',
    url: 'https://linear.app/privacy',
    svg: `<svg viewBox="0 0 24 24" fill="currentColor" xmlns="http://www.w3.org/2000/svg"><path d="M0 14.347l9.653 9.653a12.011 12.011 0 01-9.653-9.653zM0 10.46L13.54 24a12.045 12.045 0 01-2.427.223A12.01 12.01 0 010 12c0-.52.034-1.03.099-1.54zm22.133 9.312L4.228 1.867a12.01 12.01 0 0117.905 17.905zm-19.862-.379L1.007 17.13A12.016 12.016 0 010 12C0 5.373 5.373 0 12 0c1.842 0 3.583.42 5.13 1.007L2.271 19.393z"/></svg>`
  },
  {
    name: 'Vercel',
    url: 'https://vercel.com/legal/privacy-policy',
    svg: `<svg viewBox="0 0 24 24" fill="currentColor" xmlns="http://www.w3.org/2000/svg"><path d="M24 22.525H0l12-21.05 12 21.05z"/></svg>`
  },
  {
    name: 'Stripe',
    url: 'https://stripe.com/privacy',
    svg: `<svg viewBox="0 0 24 24" fill="currentColor" xmlns="http://www.w3.org/2000/svg"><path d="M13.976 9.15c-2.172-.806-3.356-1.426-3.356-2.409 0-.831.683-1.305 1.901-1.305 2.227 0 4.515.858 6.09 1.631l.89-5.494C18.252.975 15.697 0 12.165 0 9.667 0 7.589.654 6.104 1.872 4.56 3.147 3.757 4.992 3.757 7.218c0 4.039 2.467 5.76 6.476 7.219 2.585.92 3.445 1.574 3.445 2.583 0 .98-.84 1.545-2.354 1.545-1.875 0-4.965-.921-6.99-2.109l-.9 5.555C5.175 22.99 8.385 24 11.714 24c2.641 0 4.843-.624 6.328-1.813 1.664-1.305 2.525-3.236 2.525-5.732 0-4.128-2.524-5.851-6.591-7.305z"/></svg>`
  },
];


const features = [
  {
    num: '01',
    title: 'Reads the fine print',
    accent: 'so you don\'t have to',
    body: 'Tosly\'s AI scans every clause the moment you land on a ToS page — before you click accept.',
    bullets: ['Detects 40+ predatory clause types', 'Reads legal language others skip', 'Works on any site, automatically'],
  },
  {
    num: '02',
    title: 'Highlights exactly',
    accent: 'what matters',
    body: 'No summaries hidden in a popup. The actual text gets highlighted, colour-coded by severity, right on the page.',
    bullets: ['Red, yellow, green severity tiers', 'Verbatim quotes from the document', 'Navigate between flags instantly'],
  },
  {
    num: '03',
    title: 'Zero friction,',
    accent: 'total control',
    body: 'Toggle auto-scan on or off. The shield widget lives wherever you drag it. Results cached for 7 days.',
    bullets: ['Auto-scan TOS pages on load', 'Draggable, persistent widget', '7-day intelligent cache'],
  },
];

const severityConfig = {
  red:    { label: 'HIGH RISK', color: '#ef4444', bg: 'rgba(239,68,68,0.08)',   border: 'rgba(239,68,68,0.2)' },
  yellow: { label: 'CAUTION',   color: '#eab308', bg: 'rgba(234,179,8,0.08)',   border: 'rgba(234,179,8,0.2)' },
  green:  { label: 'CLEAR',     color: '#22c55e', bg: 'rgba(34,197,94,0.08)',   border: 'rgba(34,197,94,0.2)' },
};
---

<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <meta name="generator" content={Astro.generator} />
  <link rel="icon" type="image/x-icon" href="/favicon.ico" />
  <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32.png" />
  <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16.png" />
  <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />

  <!-- SEO -->
  <title>Tosly — Read Every ToS in Seconds</title>
  <meta name="description" content="Tosly is a free Chrome extension that automatically scans Terms of Service pages, flags predatory clauses in plain English, and highlights the exact text — before you click Accept." />
  <meta name="keywords" content="terms of service scanner, privacy policy analyzer, chrome extension, legal risk, ToS highlights" />
  <link rel="canonical" href="https://tosly.app/" />

  <!-- OG -->
  <meta property="og:title" content="Tosly — Read Every ToS in Seconds" />
  <meta property="og:description" content="AI-powered Chrome extension that scans Terms of Service and highlights predatory clauses before you agree to them." />
  <meta property="og:type" content="website" />
  <meta property="og:url" content="https://tosly.app/" />

  <!-- Twitter -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content="Tosly — Read Every ToS in Seconds" />
  <meta name="twitter:description" content="AI-powered Chrome extension that flags predatory clauses in any Terms of Service." />

  <!-- Fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,wght@0,300;0,400;0,500;0,600;0,700;1,400&family=Instrument+Serif:ital@0;1&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet" />

  <!-- Schema.org -->
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "SoftwareApplication",
    "name": "Tosly",
    "applicationCategory": "BrowserApplication",
    "operatingSystem": "Chrome",
    "description": "AI Chrome extension that scans Terms of Service and highlights predatory clauses.",
    "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" }
  }
  </script>

  <style>
    /* Noise texture overlay */
    .noise::after {
      content: '';
      position: absolute;
      inset: 0;
      background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noise)' opacity='0.04'/%3E%3C/svg%3E");
      pointer-events: none;
      border-radius: inherit;
    }

    /* Soft radial glow behind hero */
    .hero-glow {
      background: radial-gradient(ellipse 80% 60% at 50% -10%, rgba(239,68,68,0.06) 0%, transparent 70%),
                  radial-gradient(ellipse 60% 40% at 80% 30%, rgba(234,179,8,0.04) 0%, transparent 60%),
                  #f8f8fb;
    }

    /* Glass card */
    .glass {
      background: rgba(255,255,255,0.7);
      backdrop-filter: blur(16px);
      -webkit-backdrop-filter: blur(16px);
      border: 1px solid rgba(0,0,0,0.07);
    }

    /* Shield mock */
    .shield-mock {
      background: rgba(10,10,12,0.96);
      border: 1px solid rgba(255,255,255,0.1);
      box-shadow: 0 32px 80px rgba(0,0,0,0.25), 0 0 0 1px rgba(255,255,255,0.04) inset;
    }

    /* Ticker */
    .ticker-track {
      display: flex;
      width: max-content;
    }

    .ticker-container:hover .ticker-track {
      animation-play-state: paused;
    }

    /* Hover lift */
    .lift {
      transition: transform 0.2s ease, box-shadow 0.2s ease;
    }
    .lift:hover {
      transform: translateY(-2px);
      box-shadow: 0 12px 40px rgba(0,0,0,0.12);
    }

    /* Feature image card */
    .feat-card {
      background: rgba(255,255,255,0.6);
      border: 1px solid rgba(0,0,0,0.07);
      box-shadow: 0 2px 24px rgba(0,0,0,0.06), 0 0 0 1px rgba(255,255,255,0.8) inset;
    }
  </style>
</head>

<body class="overflow-x-hidden">

  <!-- ── Nav ───────────────────────────────────────────────────────────── -->
  <header class="fixed top-0 left-0 right-0 z-50">
    <nav class="mx-auto max-w-6xl px-6 h-16 flex items-center justify-between">
      <div class="glass rounded-full px-5 py-2.5 flex items-center gap-8 shadow-sm">
        <!-- Logo -->
        <a href="/" class="flex items-center group">
          <img src="/logo.png" alt="Tosly" height="28" style="height:28px; width:auto;" />
        </a>
        <div class="hidden md:flex items-center gap-6 text-sm font-medium">
          <a href="#how-it-works" class="text-[#6b7280] hover:text-[#0a0a0c] transition-colors">How it works</a>
          <a href="#features" class="text-[#6b7280] hover:text-[#0a0a0c] transition-colors">Features</a>
          <a href="#faq" class="text-[#6b7280] hover:text-[#0a0a0c] transition-colors">FAQ</a>
        </div>
      </div>
      <a
        href="#"
        class="glass rounded-full px-5 py-2.5 text-sm font-semibold text-[#0a0a0c] shadow-sm hover:bg-[#0a0a0c] transition-all duration-200 inline-flex items-center gap-2"
      >
        <img src="/google.svg" alt="Chrome" width="16" height="16" class="flex-shrink-0" />
        Add to Chrome — free
      </a>
    </nav>
  </header>

  <!-- ── Hero ──────────────────────────────────────────────────────────── -->
  <section class="hero-glow relative min-h-screen flex flex-col items-center justify-center pt-24 pb-16 px-6 overflow-hidden noise">

    <!-- Eyebrow -->
    <div class="animate-float-up flex items-center gap-2 mb-7 bg-white/80 border border-black/[0.07] rounded-full px-4 py-1.5 shadow-sm">
      <span class="w-1.5 h-1.5 rounded-full bg-[#22c55e] shadow-[0_0_6px_#22c55e]" style="animation: pulse-dot 2s ease-in-out infinite;"></span>
      <span class="text-xs font-medium text-[#6b7280] tracking-wide">Free Chrome Extension</span>
    </div>

    <!-- Headline -->
    <h1 class="animate-float-up delay-100 text-center max-w-3xl">
      <span style="font-family:'DM Sans',sans-serif; font-size:clamp(2.6rem,6vw,4.5rem); font-weight:700; line-height:1.08; letter-spacing:-0.03em; color:#0a0a0c; display:block;">
        You clicked Accept.<br/>
        <em style="font-family:'Instrument Serif',Georgia,serif; font-style:italic; font-weight:400; color:#ef4444;">Without reading it.</em>
      </span>
    </h1>

    <p class="animate-float-up delay-200 mt-6 text-center max-w-lg text-[#6b7280] text-[1.05rem] leading-relaxed font-normal">
      Tosly scans every Terms of Service page in seconds, flags the clauses designed to hurt you, and highlights the exact text — before you agree.
    </p>

    <!-- CTA -->
    <div class="animate-float-up delay-300 mt-9 flex flex-col sm:flex-row items-center gap-3">
      <a
        href="#"
        class="lift inline-flex items-center gap-2.5 bg-[#0a0a0c] text-white rounded-full px-7 py-3.5 text-sm font-semibold tracking-wide shadow-lg hover:bg-[#1c1c20]"
      >
        <img src="/google.svg" alt="Chrome" width="16" height="16" class="flex-shrink-0" />
        Add to Chrome — it's free
      </a>
      <a href="#how-it-works" class="text-sm font-medium text-[#6b7280] hover:text-[#0a0a0c] transition-colors">
        See how it works →
      </a>
    </div>

    <!-- Hero Video Mockup -->
    <div class="animate-float-up delay-400 mt-16 w-full max-w-3xl relative">

      <!-- Ambient glow behind the card -->
      <div class="absolute inset-0 rounded-3xl pointer-events-none" style="
        background: radial-gradient(ellipse 80% 60% at 50% 50%, rgba(239,68,68,0.18) 0%, rgba(234,179,8,0.08) 40%, transparent 70%);
        filter: blur(32px);
        transform: scale(1.08) translateY(8px);
        z-index: 0;
      "></div>

      <!-- Video thumbnail card -->
      <div id="video-trigger" class="relative z-10 rounded-2xl overflow-hidden cursor-pointer group" style="box-shadow: 0 32px 80px rgba(0,0,0,0.18), 0 0 0 1px rgba(0,0,0,0.06);">

        <!-- YouTube thumbnail -->
        <div class="relative w-full" style="aspect-ratio:16/9;">
          <img
            src="https://i.ytimg.com/vi/ivAgRwcxAH4/maxresdefault.jpg"
            alt="Watch Tosly in action"
            class="w-full h-full object-cover"
          />

          <!-- Dark overlay — lightens on hover -->
          <div class="absolute inset-0 bg-black/40 group-hover:bg-black/25 transition-colors duration-300"></div>

          <!-- Ambient colour bleed from thumbnail -->
          <div class="absolute inset-0 pointer-events-none" style="background: radial-gradient(ellipse 60% 60% at 50% 100%, rgba(239,68,68,0.15) 0%, transparent 70%);"></div>

          <!-- Play button -->
          <div class="absolute inset-0 flex items-center justify-center">
            <div class="relative flex items-center justify-center">
              <!-- Pulse rings -->
              <div class="absolute w-24 h-24 rounded-full bg-white/10 animate-ping" style="animation-duration:2s;"></div>
              <div class="absolute w-20 h-20 rounded-full bg-white/10 animate-ping" style="animation-duration:2s; animation-delay:0.4s;"></div>
              <!-- Play circle -->
              <div class="relative w-16 h-16 rounded-full flex items-center justify-center group-hover:scale-110 transition-transform duration-300"
                style="background:rgba(255,255,255,0.95); box-shadow: 0 8px 32px rgba(0,0,0,0.3);">
                <svg width="22" height="22" viewBox="0 0 24 24" fill="none">
                  <path d="M6 4.5L20 12L6 19.5V4.5Z" fill="#0a0a0c"/>
                </svg>
              </div>
            </div>
          </div>

        </div>
      </div>

    </div>
  </section>

  <!-- ── Video Modal ─────────────────────────────────────────────────────── -->
  <div id="video-modal" class="fixed inset-0 z-[9999] flex items-center justify-center p-4 md:p-8" style="display:none!important;">
    <!-- Backdrop -->
    <div id="modal-backdrop" class="absolute inset-0" style="background:rgba(0,0,0,0.85); backdrop-filter:blur(12px);"></div>

    <!-- Modal container -->
    <div id="modal-content" class="relative z-10 w-full max-w-4xl" style="opacity:0; transform:scale(0.95); transition: opacity 0.25s ease, transform 0.25s ease;">

      <!-- Ambient glow behind video -->
      <div id="modal-ambient" class="absolute pointer-events-none rounded-3xl" style="
        inset: -40px;
        background: radial-gradient(ellipse 70% 60% at 50% 50%, rgba(239,68,68,0.25) 0%, rgba(234,179,8,0.1) 50%, transparent 70%);
        filter: blur(40px);
        z-index: 0;
      "></div>

      <!-- Close button -->
      <button id="modal-close" class="absolute -top-10 right-0 text-white/60 hover:text-white transition-colors flex items-center gap-1.5 text-sm font-medium z-20">
        <svg width="16" height="16" viewBox="0 0 16 16" fill="none">
          <path d="M2 2L14 14M14 2L2 14" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
        </svg>
        Close
      </button>

      <!-- iframe wrapper -->
      <div class="relative z-10 rounded-2xl overflow-hidden" style="aspect-ratio:16/9; box-shadow: 0 40px 100px rgba(0,0,0,0.5);">
        <iframe
          id="yt-iframe"
          src=""
          title="Tosly demo"
          allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
          allowfullscreen
          class="w-full h-full border-0"
        ></iframe>
      </div>
    </div>
  </div>

  <script>
    const VIDEO_ID = 'ivAgRwcxAH4';
    const trigger  = document.getElementById('video-trigger')!;
    const modal    = document.getElementById('video-modal')!;
    const content  = document.getElementById('modal-content')!;
    const backdrop = document.getElementById('modal-backdrop')!;
    const closeBtn = document.getElementById('modal-close')!;
    const iframe   = document.getElementById('yt-iframe') as HTMLIFrameElement;
    const ambient  = document.getElementById('modal-ambient')!;

    function openModal() {
      modal.style.cssText = '';           // clear display:none
      modal.style.display = 'flex';
      iframe.src = `https://www.youtube.com/embed/${VIDEO_ID}?autoplay=1&rel=0&modestbranding=1`;
      // Animate in
      requestAnimationFrame(() => {
        content.style.opacity = '1';
        content.style.transform = 'scale(1)';
      });
      document.body.style.overflow = 'hidden';
    }

    function closeModal() {
      content.style.opacity = '0';
      content.style.transform = 'scale(0.95)';
      setTimeout(() => {
        modal.style.display = 'none';
        iframe.src = '';
        document.body.style.overflow = '';
      }, 250);
    }

    trigger.addEventListener('click', openModal);
    closeBtn.addEventListener('click', closeModal);
    backdrop.addEventListener('click', closeModal);
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape') closeModal();
    });
  </script>

  <!-- ── Logo strip ─────────────────────────────────────────────────────── -->
  <section class="py-12 border-y border-[#e5e7eb] bg-white overflow-hidden">
    <p class="text-center text-xs font-medium tracking-widest text-[#9ca3af] uppercase mb-7">
      Try it on any of these services
    </p>
    <div class="relative overflow-hidden ticker-container">
      <div class="ticker-track animate-ticker">
        {[...companies, ...companies].map(co => (
          <a
            href={co.url}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-2 mx-10 text-[#b0b4bc] hover:text-[#6b7280] transition-colors duration-200 cursor-pointer"
          >
            <span class="w-5 h-5 flex-shrink-0" set:html={co.svg} />
            <span class="text-sm font-semibold tracking-wide">{co.name}</span>
