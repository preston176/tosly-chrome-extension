        </h2>
      </div>

      <div class="space-y-28">
        {features.map((feat, i) => (
          <div class={`grid md:grid-cols-2 gap-12 items-center ${i % 2 === 1 ? 'md:[&>*:first-child]:order-2' : ''}`}>
            <!-- Text -->
            <div>
              <div class="flex items-center gap-3 mb-6">
                <span class="text-xs font-mono font-medium text-[#9ca3af]">{feat.num}</span>
                <div class="h-px flex-1 bg-[#e5e7eb]"></div>
              </div>
              <h3 style="font-family:'DM Sans',sans-serif; font-size:clamp(1.6rem,3vw,2.2rem); font-weight:700; letter-spacing:-0.02em; color:#0a0a0c; line-height:1.15;" class="mb-4">
                {feat.title}<br/>
                <em style="font-family:'Instrument Serif',Georgia,serif; font-style:italic; font-weight:400; color:#ef4444;">{feat.accent}</em>
              </h3>
              <p class="text-[#6b7280] text-base leading-relaxed mb-7">{feat.body}</p>
              <ul class="space-y-2.5">
                {feat.bullets.map(b => (
                  <li class="flex items-center gap-3 text-sm text-[#374151]">
                    <svg class="w-4 h-4 text-[#22c55e] flex-shrink-0" viewBox="0 0 16 16" fill="none">
                      <circle cx="8" cy="8" r="7.5" stroke="#22c55e" stroke-opacity="0.3"/>
                      <path d="M5 8L7 10L11 6" stroke="#22c55e" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                    </svg>
                    {b}
                  </li>
                ))}
              </ul>
            </div>

            <!-- Visual -->
            <div class="feat-card rounded-2xl p-6 min-h-[280px] flex items-center justify-center relative overflow-hidden noise">
              {i === 0 && (
                <div class="w-full space-y-2 text-xs">
                  <div class="text-[10px] font-semibold uppercase tracking-widest text-[#9ca3af] mb-4">Live scan — spotify.com</div>
                  {flags.map(flag => {
                    const cfg = severityConfig[flag.severity];
                    return (
                      <div class="rounded-lg px-3 py-2.5 flex items-start gap-2.5" style={`background:${cfg.bg}; border:1px solid ${cfg.border};`}>
                        <div class="w-1.5 h-1.5 rounded-full mt-1 flex-shrink-0" style={`background:${cfg.color};`}></div>
                        <div>
                          <div class="text-[9px] font-bold uppercase tracking-widest mb-0.5" style={`color:${cfg.color};`}>{flag.category}</div>
                          <div class="text-[10px] text-[#374151] leading-snug">{flag.text.slice(0,70)}…</div>
                        </div>
                      </div>
                    );
                  })}
                </div>
              )}
              {i === 1 && (
                <div class="w-full">
                  <div class="text-[10px] font-semibold uppercase tracking-widest text-[#9ca3af] mb-4">Highlighted on-page</div>
                  <div class="space-y-3 text-sm text-[#374151] leading-relaxed">
                    <p>By accessing our services you agree to be bound by these terms. <span class="rounded px-1 py-0.5" style="background:rgba(239,68,68,0.15); outline:1px solid rgba(239,68,68,0.4);">We may share your personal data with third-party advertising partners at our discretion.</span> Any disputes shall be resolved via binding arbitration.</p>
                    <p>Your account automatically <span class="rounded px-1 py-0.5" style="background:rgba(234,179,8,0.15); outline:1px solid rgba(234,179,8,0.4);">renews unless cancelled 24 hours before the billing period ends.</span></p>
                    <p><span class="rounded px-1 py-0.5" style="background:rgba(34,197,94,0.12); outline:1px solid rgba(34,197,94,0.35);">You may request deletion of your data at any time.</span> We will process the request within 30 days.</p>
                  </div>
                </div>
              )}
              {i === 2 && (
                <div class="flex flex-col items-center gap-4 w-full">
                  <div class="text-[10px] font-semibold uppercase tracking-widest text-[#9ca3af] mb-2">Widget settings</div>
                  <div class="glass w-full max-w-xs rounded-xl p-4 space-y-3">
                    {[
                      { label: 'Auto-scan TOS pages', on: true },
                      { label: '7-day result cache', on: true },
                      { label: 'Highlight quotes', on: true },
                    ].map(opt => (
                      <div class="flex items-center justify-between">
                        <span class="text-xs text-[#374151] font-medium">{opt.label}</span>
                        <div class="w-9 h-5 rounded-full flex items-center px-0.5" style={`background:${opt.on ? '#22c55e' : '#e5e7eb'};`}>
                          <div class={`w-4 h-4 rounded-full bg-white shadow-sm transition-transform ${opt.on ? 'translate-x-4' : ''}`}></div>
                        </div>
                      </div>
                    ))}
                  </div>
                  <div class="text-[10px] text-[#9ca3af] text-center">Position persists across all sites</div>
                </div>
              )}
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ── Severity breakdown ─────────────────────────────────────────────── -->
  <section class="py-24 px-6 hero-glow overflow-hidden noise relative">
    <div class="max-w-4xl mx-auto text-center">
      <span class="text-xs font-semibold tracking-widest uppercase text-[#ef4444] mb-3 block">Risk Tiers</span>
      <h2 style="font-family:'DM Sans',sans-serif; font-size:clamp(1.8rem,3.5vw,2.8rem); font-weight:700; letter-spacing:-0.025em; color:#0a0a0c; line-height:1.1;" class="mb-14">
