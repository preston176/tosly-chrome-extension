        ].map(item => (
          <div class="glass rounded-2xl p-8 lift relative overflow-hidden noise">
            <div class="text-[5rem] font-bold leading-none text-[#f0f0f5] absolute -top-2 -right-2 select-none" style="font-family:'JetBrains Mono',monospace;">{item.step}</div>
            <div class="w-8 h-8 rounded-full bg-[#0a0a0c] flex items-center justify-center mb-5">
