---
import '../styles/global.css';

type Severity = 'red' | 'yellow' | 'green';

const flags: { severity: Severity; category: string; text: string }[] = [
  { severity: 'red',    category: 'Data Selling',        text: 'We may share your personal data with third-party advertising partners at our discretion.' },
  { severity: 'yellow', category: 'Auto-Renewal',         text: 'Your subscription renews automatically unless cancelled 24 hours before the billing date.' },
  { severity: 'red',    category: 'Arbitration Clause',   text: 'You waive your right to participate in class-action lawsuits.' },
  { severity: 'green',  category: 'Data Deletion',        text: 'You may request complete deletion of your account and associated data at any time.' },
  { severity: 'yellow', category: 'Price Changes',        text: 'We reserve the right to modify pricing with 30 days notice via email.' },
];

const companies = [
  {
    name: 'Spotify',
